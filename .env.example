# 复习笔记助手 - 配置模板
# 用法二选一：
#   1) 运行 py setup.py 交互式生成（推荐）
#   2) 复制本文件为 .env，手动填好下面的值
# .env 已被 .gitignore 忽略，不会随仓库上传，可放心填真实密钥。

# ===== 大模型接口（OpenAI 兼容）=====
# 常见服务商参考：
#   智谱 GLM:      https://open.bigmodel.cn/api/paas/v4/           模型: glm-4-plus / glm-4-flash
#   DeepSeek:      https://api.deepseek.com                         模型: deepseek-chat
#   通义千问 Qwen: https://dashscope.aliyuncs.com/compatible-mode/v1 模型: qwen-plus / qwen-turbo
#   Moonshot Kimi: https://api.moonshot.cn/v1                       模型: moonshot-v1-8k
#   OpenAI:        https://api.openai.com/v1                        模型: gpt-4o-mini
REVIEW_API_BASE=
REVIEW_API_KEY=
REVIEW_MODEL=

# ===== 默认运行参数（可选，命令行可覆盖）=====
# 不想每次都带 --course / --discipline 时在这里设默认值
# REVIEW_COURSE=未命名课程
# REVIEW_DISCIPLINE=auto
